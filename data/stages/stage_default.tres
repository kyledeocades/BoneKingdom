[ext_resource type="Script" path="res://scripts/managers/StageConfig.gd" id="1_stage_config"]

[resource]
script = ExtResource("1_stage_config")
stage_id = "default"
stage_name = "Default Stage"
base_distance = 2000.0 # Distance from CENTER to place BASES
mine_distance = 400.0 # Distance FROM BASES toward CENTER to place MINES
allowed_player_units = [] # List of unit IDs that the player can use in this stage. If empty, all units are allowed.
